{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/generate",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/discover",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/process",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "api/cron/process.js": {
      "maxDuration": 60
    }
  }
}
